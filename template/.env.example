# Gamvio Game SDK Configuration
# Get these values from the Gamvio Developer Portal: https://dev.gamv.io

# Your Game ID (UUID from developer portal)
GAMVIO_GAME_ID=your-game-id-here

# API Secret key (gv_secret_xxx — keep this secret, never expose to browser)
GAMVIO_API_SECRET=gv_secret_your_secret_here

# Gamvio API URL (default: https://gamv.io)
GAMVIO_API_URL=https://gamv.io
